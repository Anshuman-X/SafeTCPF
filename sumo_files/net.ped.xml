        <walk edges="E_to_C C_to_W"/>
    </personFlow>
    <personFlow id="pflow_3" type="ped" begin="0" end="1000" probability="0.025000">
        <walk edges="W_to_C C_to_E"/>
    </personFlow>
    <personFlow id="pflow_4" type="ped" begin="0" end="1000" probability="0.025000">
